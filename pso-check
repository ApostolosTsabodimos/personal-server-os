MANIFEST_REQUIRED_FIELDS = ["id", "name", "version", "description", "category", "installation"]
MANIFEST_REQUIRED_INSTALLATION = ["method", "image"]

def run_manifest_checks():
    totals   = {"PASS": 0, "WARN": 0, "FAIL": 0}
    failures = []

    services_dir = SCRIPT_DIR / "services"
    schema_path  = SCRIPT_DIR / "core" / "schemas" / "manifest_v1.schema.json"

    # Load JSON schema if available
    schema = None
    if schema_path.exists():
        try:
            import json
            schema = json.loads(schema_path.read_text())
        except Exception:
            pass

    # ── Service manifests ────────────────────────────────────────────────────
    print(f"\n{CYAN}{BOLD}  [Service Manifests]{RESET}")
    print(f"  {GRAY}{'─' * 60}{RESET}")

    manifests = sorted(services_dir.glob("*/manifest.json")) if services_dir.exists() else []
    for mpath in manifests:
        svc = mpath.parent.name
        t0 = time.time()
        issues = []
        warns  = []
        try:
            import json
            data = json.loads(mpath.read_text())

            # Required top-level fields
            missing = [f for f in MANIFEST_REQUIRED_FIELDS if f not in data]
            if missing:
                issues.append(f"missing fields: {', '.join(missing)}")

            # Installation sub-fields
            inst = data.get("installation", {})
            missing_inst = [f for f in MANIFEST_REQUIRED_INSTALLATION if f not in inst]
            if missing_inst:
                issues.append(f"installation missing: {', '.join(missing_inst)}")

            # id matches directory name
            if data.get("id") and data["id"] != svc:
                warns.append(f"id '{data['id']}' != directory '{svc}'")

            # ports is a dict if present
            if "ports" in data and not isinstance(data["ports"], dict):
                issues.append("ports must be a dict")

            # volumes is a list if present
            if "volumes" in data and not isinstance(data["volumes"], list):
                issues.append("volumes must be a list")

            # JSON schema validation
            if schema:
                try:
                    import jsonschema
                    jsonschema.validate(data, schema)
                except ImportError:
                    pass  # jsonschema not installed, skip
                except jsonschema.ValidationError as e:
                    warns.append(f"schema: {e.message[:60]}")

        except json.JSONDecodeError as e:
            issues.append(f"invalid JSON: {e}")
        except Exception as e:
            issues.append(f"{type(e).__name__}: {e}")

        elapsed = time.time() - t0
        status  = "FAIL" if issues else "WARN" if warns else "PASS"
        totals[status] += 1
        icon = {"PASS": _PASS, "WARN": _WARN, "FAIL": _FAIL}[status]
        print(f"  {icon}  {svc:<40} {GRAY}({elapsed:.3f}s){RESET}")
        for m in issues: print(f"         {RED}✗ {m}{RESET}")
        for m in warns:  print(f"         {YELLOW}! {m}{RESET}")
        if status == "FAIL":
            failures.append((f"manifest: {svc}", issues))

    if not manifests:
        print(f"  {_WARN}  No manifests found in services/")
        totals["WARN"] += 1

    # ── Script syntax checks ─────────────────────────────────────────────────
    print(f"\n{CYAN}{BOLD}  [Script Syntax]{RESET}")
    print(f"  {GRAY}{'─' * 60}{RESET}")

    bash_scripts = [SCRIPT_DIR / "pso", SCRIPT_DIR / "pso-menu"]
    for script in bash_scripts:
        t0 = time.time()
        if not script.exists():
            print(f"  {_WARN}  {script.name:<40} {GRAY}missing{RESET}")
            totals["WARN"] += 1
            continue
        try:
            r = subprocess.run(["bash", "-n", str(script)], capture_output=True, text=True)
            elapsed = time.time() - t0
            if r.returncode == 0:
                totals["PASS"] += 1
                print(f"  {_PASS}  {script.name:<40} {GRAY}({elapsed:.2f}s){RESET}")
            else:
                totals["FAIL"] += 1
                err = r.stderr.strip().splitlines()[0] if r.stderr.strip() else "syntax error"
                print(f"  {_FAIL}  {script.name:<40} {GRAY}({elapsed:.2f}s){RESET}")
                print(f"         {RED}✗ {err}{RESET}")
                failures.append((script.name, [err]))
        except Exception as e:
            totals["FAIL"] += 1
            print(f"  {_FAIL}  {script.name:<40} {RED}{e}{RESET}")
            failures.append((script.name, [str(e)]))

    py_scripts = [
        SCRIPT_DIR / "pso.py",
        SCRIPT_DIR / "scripts" / "update_manifests.py",
        SCRIPT_DIR / "core" / "manifest_validator.py",
    ]
    for script in py_scripts:
        t0 = time.time()
        if not script.exists():
            continue
        try:
            import ast as _ast
            _ast.parse(script.read_text())
            elapsed = time.time() - t0
            totals["PASS"] += 1
            print(f"  {_PASS}  {script.name:<40} {GRAY}({elapsed:.2f}s){RESET}")
        except SyntaxError as e:
            elapsed = time.time() - t0
            totals["FAIL"] += 1
            msg = f"line {e.lineno}: {e.msg}"
            print(f"  {_FAIL}  {script.name:<40} {GRAY}({elapsed:.2f}s){RESET}")
            print(f"         {RED}✗ {msg}{RESET}")
            failures.append((script.name, [msg]))

    # ── Web assets ───────────────────────────────────────────────────────────
    print(f"\n{CYAN}{BOLD}  [Web Assets]{RESET}")
    print(f"  {GRAY}{'─' * 60}{RESET}")

    web_assets = [
        ("web/static/index.html",  None),
        ("web/static/login.html",  None),
        ("web/static/app.js",      None),
        ("web/static/styles.css",  None),
        ("web/static/auth-helper.js", None),
    ]
    for rel, _ in web_assets:
        path = SCRIPT_DIR / rel
        t0   = time.time()
        if not path.exists():
            totals["WARN"] += 1
            print(f"  {_WARN}  {rel:<40} {GRAY}missing{RESET}")
            continue
        size_kb = path.stat().st_size / 1024
        elapsed = time.time() - t0
        totals["PASS"] += 1
        print(f"  {_PASS}  {rel:<40} {GRAY}({size_kb:.1f} KB){RESET}")

    # ── Requirements ─────────────────────────────────────────────────────────
    print(f"\n{CYAN}{BOLD}  [Requirements]{RESET}")
    print(f"  {GRAY}{'─' * 60}{RESET}")

    for req_file in ["requirements.txt", "web/requirements-web.txt"]:
        path = SCRIPT_DIR / req_file
        if not path.exists():
            continue
        t0 = time.time()
        # pip package name -> actual importable module name (when they differ)
        _IMPORT_NAMES = {
            "PyJWT":       "jwt",
            "flask-cors":  "flask_cors",
            "Pillow":      "PIL",
            "beautifulsoup4": "bs4",
            "python-dateutil": "dateutil",
            "python-dotenv":   "dotenv",
        }
        missing_pkgs = []
        for line in path.read_text().splitlines():
            line = line.strip()
            if not line or line.startswith("#"):
                continue
            pkg = line.split(">=")[0].split("==")[0].split("<=")[0].strip()
            module = _IMPORT_NAMES.get(pkg, pkg.replace("-", "_"))
            try:
                importlib.import_module(module)
            except ImportError:
                missing_pkgs.append(pkg)
        elapsed = time.time() - t0
        if missing_pkgs:
            totals["WARN"] += 1
            print(f"  {_WARN}  {req_file:<40} {GRAY}({elapsed:.2f}s){RESET}")
            print(f"         {YELLOW}! not installed: {', '.join(missing_pkgs)}{RESET}")
        else:
            totals["PASS"] += 1
            print(f"  {_PASS}  {req_file:<40} {GRAY}({elapsed:.2f}s){RESET}")

    # ── Systemd unit ─────────────────────────────────────────────────────────
    unit = SCRIPT_DIR / "systemd" / "pso-health-monitor.service"
    if unit.exists():
        print(f"\n{CYAN}{BOLD}  [Systemd]{RESET}")
        print(f"  {GRAY}{'─' * 60}{RESET}")
        t0 = time.time()
        content = unit.read_text()
        issues = []
        for required in ("[Unit]", "[Service]", "ExecStart"):
            if required not in content:
                issues.append(f"missing section: {required}")
        elapsed = time.time() - t0
        if issues:
            totals["FAIL"] += 1
            print(f"  {_FAIL}  pso-health-monitor.service      {GRAY}({elapsed:.2f}s){RESET}")
            for m in issues: print(f"         {RED}✗ {m}{RESET}")
            failures.append(("pso-health-monitor.service", issues))
        else:
            totals["PASS"] += 1
            print(f"  {_PASS}  pso-health-monitor.service      {GRAY}({elapsed:.2f}s){RESET}")

    return totals, failures


