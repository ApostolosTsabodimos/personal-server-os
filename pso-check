def _test_update_security(t: T):
    import tempfile, hashlib
    from core.update_security import compute_checksum, verify_checksum
    # write a temp file and verify checksum round-trip
    with tempfile.NamedTemporaryFile(delete=False, suffix=".tar.gz") as f:
        f.write(b"fake update payload content")
        tmp = Path(f.name)
    try:
        checksum = compute_checksum(tmp)
        t.assert_true("checksum is non-empty string", isinstance(checksum, str) and len(checksum) > 8)
        ok = verify_checksum(tmp, checksum)
        t.assert_true("checksum verifies correctly", ok)
        bad = verify_checksum(tmp, "0" * len(checksum))
        t.assert_true("wrong checksum rejected", not bad)
    finally:
        tmp.unlink(missing_ok=True)


