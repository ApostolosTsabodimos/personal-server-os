class T:
    """Tiny test runner for one named test."""
    def __init__(self, name):
        self.name    = name
        self.passed  = 0
        self.failed  = 0
        self.details = []

    def ok(self, label):
        self.passed += 1
        self.details.append((True, label))

    def fail(self, label, reason=""):
        self.failed += 1
        self.details.append((False, f"{label}: {reason}" if reason else label))

    def assert_eq(self, label, got, expected):
        if got == expected:
            self.ok(label)
        else:
            self.fail(label, f"expected {expected!r}, got {got!r}")

    def assert_true(self, label, value, reason=""):
        if value:
            self.ok(label)
        else:
            self.fail(label, reason or f"got falsy: {value!r}")

    def assert_not_none(self, label, value):
        if value is not None:
            self.ok(label)
        else:
            self.fail(label, "got None")

    def assert_in(self, label, needle, haystack):
        if needle in haystack:
            self.ok(label)
        else:
            self.fail(label, f"{needle!r} not in result")

    @property
    def status(self):
        if self.failed:   return "FAIL"
        if self.passed:   return "PASS"
        return "SKIP"


def _run_test(t: T, fn):
    """Run fn(t), catching any uncaught exception as a test failure."""
    try:
        fn(t)
    except Exception as e:
        t.fail("uncaught exception", f"{type(e).__name__}: {e}")


