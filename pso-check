        if not functional_only and not cli_only:
            t = len(components)
            lines.append(f"  {'Structural':<22} {struct_totals['PASS']:>7} {struct_totals['WARN']:>7} {struct_totals['FAIL']:>7} {t:>7}")
        if not quick and not cli_only:
            t = len(FUNCTIONAL_TESTS)
            lines.append(f"  {'Functional':<22} {func_totals['PASS']:>7} {func_totals.get('WARN',0):>7} {func_totals['FAIL']:>7} {t:>7}")
        if not quick and not functional_only:
            t = sum(cli_totals.values())
            lines.append(f"  {'CLI Commands':<22} {cli_totals['PASS']:>7} {cli_totals.get('WARN',0):>7} {cli_totals['FAIL']:>7} {t:>7}")
        if not quick and not functional_only and not cli_only or manifests_only:
            t = sum(manifest_totals.values())
            lines.append(f"  {'Manifests':<22} {manifest_totals['PASS']:>7} {manifest_totals.get('WARN',0):>7} {manifest_totals['FAIL']:>7} {t:>7}")
        if not quick and not functional_only and not cli_only or tests_only:
            t = sum(tests_totals.values())
            lines.append(f"  {'Test Suite':<22} {tests_totals['PASS']:>7} {tests_totals.get('WARN',0):>7} {tests_totals['FAIL']:>7} {t:>7}")
        lines.append("")

        # ── Overall verdict ──────────────────────────────────────────
        if all_failures:
            lines.append(f"  RESULT: FAILED  ({len(all_failures)} failure(s))")
        else:
            lines.append(f"  RESULT: ALL CHECKS PASSED")
        lines.append("")

        # ── Failures (detailed) ──────────────────────────────────────
        if all_failures:
            lines += _section("FAILURES")
            lines.append("")
            for label, msgs in all_failures:
                lines.append(f"  FAIL  {label}")
                for m in (msgs if msgs else []):
                    lines.append(f"        {m}")
                lines.append("")

        # ── Warnings ─────────────────────────────────────────────────
        # collect from all_failures that are warns — stored separately
        # also emit per-phase detail blocks

        # ── Phase detail: Manifests ──────────────────────────────────
        if not quick and not functional_only and not cli_only or manifests_only:
            lines += _section("PHASE 4 — MANIFEST DETAIL")
            lines.append("")
            lines.append(f"  {'Service':<25} {'id':<20} {'Version':<12} {'Category':<15} Status")
            lines.append("  " + "-" * 80)
            import json as _json
            services_dir = SCRIPT_DIR / "services"
            for mpath in sorted(services_dir.glob("*/manifest.json")) if services_dir.exists() else []:
                svc = mpath.parent.name
                try:
                    d = _json.loads(mpath.read_text())
                    mid  = d.get("id", "?")
                    ver  = d.get("version", "?")
                    cat  = d.get("category", "?")
                    img  = d.get("installation", {}).get("image", "?")
                    ports = ", ".join(f"{k}:{v}" for k,v in d.get("ports", {}).items()) or "-"
                    status = "OK"
                    missing = [f for f in ["id","name","version","description","category","installation"] if f not in d]
                    if missing:
                        status = f"MISSING: {', '.join(missing)}"
                    lines.append(f"  {svc:<25} {mid:<20} {ver:<12} {cat:<15} {status}")
                    lines.append(f"    image: {img}  ports: {ports}")
                except Exception as e:
                    lines.append(f"  {svc:<25} ERROR: {e}")
            lines.append("")

        # ── Phase detail: Structural ─────────────────────────────────
        if not functional_only and not cli_only:
            lines += _section("PHASE 1 — STRUCTURAL DETAIL")
            lines.append("")
            for comp in components:
                cid   = comp["id"]
                cfile = comp.get("file", "")
                lines.append(f"  {cid:<35} {cfile}")
            lines.append("")

        # ── Phase detail: Functional ─────────────────────────────────
        if not quick and not cli_only:
            lines += _section("PHASE 2 — FUNCTIONAL TESTS")
            lines.append("")
            for name, layer, fn in FUNCTIONAL_TESTS:
                lines.append(f"  {name:<35} [{layer}]")
            lines.append("")

        # ── Phase detail: CLI ─────────────────────────────────────────
        if not quick and not functional_only:
            lines += _section("PHASE 3 — CLI COMMANDS TESTED")
            lines.append("")
            for cmd_entry in CLI_COMMANDS:
                label = cmd_entry.get("label", "")
                cmd   = " ".join(cmd_entry.get("cmd", []))
                lines.append(f"  {label:<40} {cmd}")
            lines.append("")

        lines.append("")
        with open(path, "w", encoding="utf-8") as f:
            f.write("\n".join(lines) + "\n")
        print(f"\n  {GREEN}Report saved to: {path}{RESET}\n")
    else:
        print()

    # ── Teardown ─────────────────────────────────────────────────────────────
    if cleanup:
        teardown()
        print(f"  {GRAY}Test environment cleaned up.{RESET}\n")
    else:
        print(f"  {YELLOW}Test environment kept at: {TEST_DIR}{RESET}\n")

    return exit_code


# ─────────────────────────────────────────────────────────────────────────────
# Entry point
# ─────────────────────────────────────────────────────────────────────────────

def main():
    args = sys.argv[1:]

    quick          = "--quick"          in args
    functional_only= "--functional"     in args
    cli_only       = "--cli-only"       in args
    manifests_only = "--manifests"      in args
    tests_only     = "--tests"          in args
    no_cleanup     = "--no-cleanup"     in args
    args = [a for a in args if a not in
            ("--quick", "--functional", "--cli-only", "--manifests", "--tests", "--no-cleanup")]

    filter_id    = None
    filter_layer = None
    i = 0
    while i < len(args):
        if args[i] == "--component" and i + 1 < len(args):
            filter_id = args[i+1]; i += 2
        elif args[i] == "--layer" and i + 1 < len(args):
            filter_layer = args[i+1]; i += 2
        elif args[i] in ("--help", "-h"):
            print(__doc__); sys.exit(0)
        else:
            i += 1

    sys.exit(run(
        quick=quick,
        functional_only=functional_only,
        cli_only=cli_only,
        manifests_only=manifests_only,
        tests_only=tests_only,
        filter_layer=filter_layer,
        filter_id=filter_id,
        cleanup=not no_cleanup,
    ))


if __name__ == "__main__":
    main()