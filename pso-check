def _find_pytest_python(script_dir):
    """Find a working python with pytest available."""
    candidates = [
        script_dir / ".venv" / "bin" / "python3",
        script_dir / ".venv" / "bin" / "python",
        script_dir / "web" / ".venv" / "bin" / "python3",
        Path(sys.executable),
    ]
    for p in candidates:
        if not p.exists():
            continue
        try:
            resolved = p.resolve()
            if resolved.exists():
                return str(p)
        except Exception:
            pass
    return sys.executable


def run_existing_tests(env):
    totals   = {"PASS": 0, "WARN": 0, "FAIL": 0}
    failures = []
    tests_dir = SCRIPT_DIR / "tests"

    print(f"\n{CYAN}{BOLD}  [Existing Tests]{RESET}")
    print(f"  {GRAY}{'─' * 60}{RESET}")

    test_files = sorted(tests_dir.glob("test_*.py")) if tests_dir.exists() else []
    sh_files   = sorted(tests_dir.glob("test_*.sh"))  if tests_dir.exists() else []

    if not test_files and not sh_files:
        print(f"  {_WARN}  No test files found in tests/")
        totals["WARN"] += 1
        return totals, failures

    for tf in test_files:
        t0 = time.time()
        try:
            # Strip pso-check's test env vars so components like ManifestLoader
            # fall back to their defaults (e.g. finding services/ via __file__)
            pytest_env = {k: v for k, v in env.items()
                          if k not in ("PSO_DEV_DIR", "PSO_TEST_MODE")}
            r = subprocess.run(
                [_find_pytest_python(SCRIPT_DIR), "-m", "pytest", str(tf), "-q", "--tb=short", "--no-header"],
                capture_output=True, text=True, timeout=60,
                cwd=str(SCRIPT_DIR), env=pytest_env
            )
            elapsed = time.time() - t0
            out = r.stdout + r.stderr
            if r.returncode == 0:
                totals["PASS"] += 1
                passed_line = next((l for l in out.splitlines() if "passed" in l), "")
                print(f"  {_PASS}  {tf.name:<40} {GRAY}{passed_line.strip()[:30]} ({elapsed:.2f}s){RESET}")
            else:
                totals["FAIL"] += 1
                err_lines = [l for l in out.splitlines() if l.strip()][-15:]
                summary = err_lines[-1].strip()[:70] if err_lines else "failed"
                print(f"  {_FAIL}  {tf.name:<40} {GRAY}({elapsed:.2f}s){RESET}")
                for l in err_lines:
                    print(f"         {RED}{l}{RESET}")
                failures.append((tf.name, [summary]))
        except subprocess.TimeoutExpired:
            totals["FAIL"] += 1
            print(f"  {_FAIL}  {tf.name:<40} {RED}timed out (60s){RESET}")
            failures.append((tf.name, ["timed out"]))
        except Exception as e:
            totals["WARN"] += 1
            print(f"  {_WARN}  {tf.name:<40} {YELLOW}{e}{RESET}")

    for tf in sh_files:
        t0 = time.time()
        try:
            r = subprocess.run(
                ["bash", str(tf)], capture_output=True, text=True,
                timeout=30, cwd=str(SCRIPT_DIR), env=env
            )
            elapsed = time.time() - t0
            if r.returncode == 0:
                totals["PASS"] += 1
                print(f"  {_PASS}  {tf.name:<40} {GRAY}({elapsed:.2f}s){RESET}")
            else:
                totals["FAIL"] += 1
                err = (r.stderr or r.stdout).strip().splitlines()[-1][:70] if (r.stderr or r.stdout).strip() else "failed"
                print(f"  {_FAIL}  {tf.name:<40} {GRAY}({elapsed:.2f}s){RESET}")
                print(f"         {RED}✗ {err}{RESET}")
                failures.append((tf.name, [err]))
        except Exception as e:
            totals["WARN"] += 1
            print(f"  {_WARN}  {tf.name:<40} {YELLOW}{e}{RESET}")

    return totals, failures


