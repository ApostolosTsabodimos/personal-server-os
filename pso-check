def run_functional():
    totals  = {"PASS": 0, "WARN": 0, "FAIL": 0}
    results = []
    current_layer = None

    for name, layer, fn in FUNCTIONAL_TESTS:
        if layer != current_layer:
            current_layer = layer
            print(f"\n{CYAN}{BOLD}  [{layer}]{RESET}")
            print(f"  {GRAY}{'─' * 60}{RESET}")

        t = T(name)
        t0 = time.time()
        _run_test(t, fn)
        elapsed = time.time() - t0

        icon = {"PASS": _PASS, "WARN": _WARN, "FAIL": _FAIL, "SKIP": _SKIP}[t.status]
        sub  = f"{GREEN}{t.passed}✓{RESET} {RED}{t.failed}✗{RESET}"
        print(f"  {icon}  {name:<38} {sub}  {GRAY}({elapsed:.2f}s){RESET}")

        for ok, detail in t.details:
            if not ok:
                print(f"         {RED}✗ {detail}{RESET}")

        totals[t.status] = totals.get(t.status, 0) + 1
        if t.status == "FAIL":
            results.append((name, [d for ok, d in t.details if not ok]))

    return totals, results


