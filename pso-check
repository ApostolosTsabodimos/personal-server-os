def _test_database(t: T):
    from core.database import Database
    db = Database()
    t.assert_true("Database instantiates", db is not None)
    # add a fake service
    ok = db.add_service({
        "service_id": "test-svc",
        "service_name": "nginx",
        "version": "1.0",
        "category": "web",
        "status": "stopped",
        "installation_method": "docker",
    })
    t.assert_true("add_service succeeds", ok)
    svc = db.get_service("test-svc")
    t.assert_not_none("get_service returns entry", svc)
    name_val = svc.get("service_name") if isinstance(svc, dict) else None
    t.assert_eq("service name correct", name_val, "nginx")
    # list
    svcs = db.list_services()
    t.assert_true("list_services returns list", isinstance(svcs, list))
    t.assert_true("test-svc in list", any(s.get("service_id") == "test-svc" for s in svcs))
    # update status
    db.update_service_status("test-svc", "running")
    svc2 = db.get_service("test-svc")
    t.assert_eq("status updated", svc2.get("status"), "running")
    # is_installed
    t.assert_true("is_installed true", db.is_installed("test-svc"))
    # remove
    db.remove_service("test-svc")
    gone = db.get_service("test-svc")
    t.assert_true("service removed", gone is None)
    t.assert_true("is_installed false after remove", not db.is_installed("test-svc"))


def _test_auth(t: T):
    from core.auth import Auth
    from core.database import Database
    db   = Database()
    auth = Auth(db)
    t.assert_true("Auth instantiates", auth is not None)
    # register user
    result = auth.register_user("testuser_chk", "Test1234!")
    t.assert_true("register_user succeeds", result)
    # login
    login_result = auth.login("testuser_chk", "Test1234!")
    t.assert_not_none("login returns result", login_result)
    token = login_result.get("token") or login_result.get("access_token") if isinstance(login_result, dict) else login_result
    t.assert_not_none("token present", token)
    # validate token
    payload = auth.validate_token(token)
    t.assert_not_none("validate_token returns payload", payload)
    t.assert_true("username in payload", payload.get("username") == "testuser_chk" or payload.get("sub") == "testuser_chk")
    # wrong password
    try:
        bad = auth.login("testuser_chk", "wrongpassword")
        t.assert_true("wrong password rejected", not bad or bad.get("error"))
    except Exception:
        t.ok("wrong password raises exception (expected)")
    # list users and find ours
    users = auth.list_users()
    t.assert_true("list_users returns list", isinstance(users, list))
    user_entry = next((u for u in users if u.get("username") == "testuser_chk"), None)
    t.assert_not_none("user in list", user_entry)
    # delete user by id
    uid = user_entry.get("id") or user_entry.get("user_id")
    auth.delete_user(uid)
    users2 = auth.list_users()
    t.assert_true("user removed", not any(u.get("username") == "testuser_chk" for u in users2))


def _test_secrets(t: T):
    from core.secrets_manager import SecretsManager
