def _check_file_exists(comp):
    path = SCRIPT_DIR / comp["file"]
    return (True, "found") if path.exists() else (False, f"missing: {comp['file']}")

def _check_service_catalog(comp):
    d = SCRIPT_DIR / "services"
    if not d.exists(): return False, "services/ directory missing"
    m = list(d.glob("*/manifest.json"))
    return (True, f"{len(m)} manifests") if m else (None, "no manifests found")

def _check_cli(comp):
    cli = SCRIPT_DIR / "pso"
    if not cli.exists(): return False, "pso script missing"
    if not os.access(cli, os.X_OK): return None, "not executable"
    return True, "present and executable"

def _check_web_dashboard(comp):
    missing = [f for f in ["web/static/index.html","web/static/app.js","web/static/styles.css"]
               if not (SCRIPT_DIR / f).exists()]
    return (False, f"missing: {', '.join(missing)}") if missing else (True, "files present")

CUSTOM = {
    "check_service_catalog": _check_service_catalog,
    "check_cli":             _check_cli,
    "check_file_exists":     _check_file_exists,
    "check_web_dashboard":   _check_web_dashboard,
}

def _structural_check(comp):
    issues, warnings, passed = [], [], []

    if "custom_check" in comp:
        ok, msg = CUSTOM[comp["custom_check"]](comp)
        (passed if ok is True else issues if ok is False else warnings).append(msg)
        return ("FAIL" if issues else "WARN" if warnings else "PASS"), issues, warnings, passed

    if not (SCRIPT_DIR / comp["file"]).exists():
        return "FAIL", [f"file missing: {comp['file']}"], [], []
    passed.append("file exists")

    mod_name = comp.get("module")
    if mod_name:
        try:
            mod = importlib.import_module(mod_name)
            passed.append("import OK")
            missing_fns = [f for f in comp.get("functions", []) if not hasattr(mod, f)]
            if missing_fns:
                issues.append(f"missing: {', '.join(missing_fns)}")
            elif comp.get("functions"):
                passed.append("functions present")
        except ImportError as e:
            issues.append(f"ImportError: {e}")
        except Exception as e:
            issues.append(f"{type(e).__name__}: {e}")

    if not issues:
        tables = comp.get("db_tables", [])
        if tables and TEST_DB.exists():
            try:
                conn = sqlite3.connect(TEST_DB)
                existing = {r[0] for r in conn.execute(
                    "SELECT name FROM sqlite_master WHERE type='table'").fetchall()}
                conn.close()
                missing = [t for t in tables if t not in existing]
                if missing: warnings.append(f"tables missing: {', '.join(missing)}")
                else:        passed.append(f"{len(tables)} table(s) OK")
            except Exception as e:
                warnings.append(f"DB check error: {e}")

    return ("FAIL" if issues else "WARN" if warnings else "PASS"), issues, warnings, passed


def run_structural(components, filter_id=None, filter_layer=None):
    totals  = {"PASS": 0, "WARN": 0, "FAIL": 0}
    results = []
    current_layer = None

    for comp in components:
        if comp["layer"] != current_layer:
            current_layer = comp["layer"]
            print(f"\n{CYAN}{BOLD}  [{current_layer}]{RESET}")
            print(f"  {GRAY}{'─' * 60}{RESET}")

        t0 = time.time()
        status, issues, warnings, passed = _structural_check(comp)
        elapsed = time.time() - t0
        totals[status] += 1

        icon = {"PASS": _PASS, "WARN": _WARN, "FAIL": _FAIL}[status]
        print(f"  {icon}  {comp['name']:<40} {GRAY}({elapsed:.2f}s){RESET}")
        for m in issues:   print(f"         {RED}✗ {m}{RESET}")
        for m in warnings: print(f"         {YELLOW}! {m}{RESET}")
        if (filter_id or filter_layer) and status == "PASS":
            for m in passed: print(f"         {GRAY}· {m}{RESET}")

        if status == "FAIL":
            results.append((comp["name"], issues))

    return totals, results


