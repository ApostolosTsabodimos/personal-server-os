def _test_rbac(t: T):
    from core.rbac import RBAC
    rbac = RBAC()
    t.assert_true("RBAC instantiates", rbac is not None)
    # list built-in roles
    roles = rbac.list_roles()
    t.assert_true("list_roles returns list", isinstance(roles, list))
    # create role
    # discover what permissions the system accepts by checking existing roles
    existing_roles = rbac.list_roles()
    valid_perms = set()
    for r in existing_roles:
        rname = r.get("name") if isinstance(r, dict) else r
        try:
            perms = rbac.get_permissions(rname)
            valid_perms.update(perms)
        except Exception:
            pass
    # use a known valid permission or fall back to viewer perm
    test_perm = next(iter(valid_perms)) if valid_perms else "services.list"
    rbac.create_role("test_role", "Test role for pso-check", permissions=[test_perm])
    roles2 = rbac.list_roles()
    t.assert_true("test_role created", any(
        (r.get("name") if isinstance(r, dict) else r) == "test_role" for r in roles2
    ))
    # assign and check
    rbac.assign_role("testuser_rbac", "test_role")
    t.assert_true("user has assigned permission", rbac.check("testuser_rbac", test_perm))
    t.assert_true("user lacks admin permission", not rbac.check("testuser_rbac", "admin"))
    user_roles = rbac.get_user_roles("testuser_rbac")
    t.assert_in("role assigned to user", "test_role", user_roles)
    # cleanup
    rbac.revoke_role("testuser_rbac", "test_role")
    rbac.delete_role("test_role")


