def run_cli_sweep(env):
    totals   = {"PASS": 0, "WARN": 0, "FAIL": 0}
    failures = []

    print(f"{CYAN}{BOLD}  [CLI COMMANDS]  ({len(CLI_COMMANDS)} commands){RESET}")
    print(f"  {GRAY}{'─' * 60}{RESET}")

    for entry in CLI_COMMANDS:
        label     = entry["label"]
        warn_only = entry.get("warn_only", False)
        t0 = time.time()
        try:
            r = subprocess.run(
                entry["cmd"], capture_output=True, text=True,
                timeout=15, cwd=str(SCRIPT_DIR), env=env,
            )
            elapsed = time.time() - t0
            out = r.stdout + r.stderr

            if "Traceback (most recent call last)" in out:
                status = "WARN" if warn_only else "FAIL"
                lines  = out.strip().splitlines()
                detail = next((l.strip() for l in reversed(lines)
                               if l.strip() and not l.startswith(" ")), "traceback")[:80]
            elif r.returncode != 0 and any(x in out[:120] for x in ["Unknown command:", "Unknown "]):
                status, detail = ("WARN" if warn_only else "FAIL"), f"routing error (exit {r.returncode})"
            elif r.returncode != 0 and any(x in out for x in ["Error:", "Exception:", "FAILED"]):
                status = "WARN"
                detail = (out.strip().splitlines()[0] if out.strip() else f"exit {r.returncode}")[:70]
            else:
                status, detail = "PASS", ""
        except subprocess.TimeoutExpired:
            elapsed = 15.0
            status, detail = ("WARN" if warn_only else "FAIL"), "timed out (15s)"
        except Exception as e:
            elapsed = time.time() - t0
            status, detail = ("WARN" if warn_only else "FAIL"), str(e)

        totals[status] += 1
        icon = {"PASS": _PASS, "WARN": _WARN, "FAIL": _FAIL}[status]
        print(f"  {icon}  {label:<44} {GRAY}({elapsed:.2f}s){RESET}")
        if detail and status != "PASS":
            colour = YELLOW if status == "WARN" else RED
            print(f"         {colour}! {detail}{RESET}")
        if status == "FAIL":
            failures.append((label, detail))

    return totals, failures


