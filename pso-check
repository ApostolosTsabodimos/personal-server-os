def _bootstrap_schemas():
    """Create all component schemas in the test DB.

    Two-pass strategy:
    1. Try to instantiate each component class (triggers its own _ensure_schema)
       but patch its module-level DB_PATH first so it points at TEST_DB.
    2. For any table that still doesn't exist, create it directly via SQL.
    """
    # Pass 1: instantiate components, overriding their cached DB_PATH
    for module_name, class_name in [
        ("core.health_monitor",   "HealthMonitor"),
        ("core.metrics",          "MetricsCollector"),
        ("core.log_aggregator",   "LogStore"),
        ("core.auth",             "Auth"),
        ("core.rbac",             "RBAC"),
        ("core.audit_log",        "AuditLogger"),
        ("core.update_monitor",   None),
        ("core.update_processor", "UpdateProcessor"),
        ("core.network_manager",  None),
        ("core.storage_manager",  None),
        ("core.backup_manager",   "BackupManager"),
        ("core.resource_manager", "ResourceManager"),
        ("core.rate_limiter",     "RateLimiter"),
        ("core.secrets_manager",  "SecretsManager"),
    ]:
        try:
            mod = importlib.import_module(module_name)
            # Override any cached DB_PATH in the module
            if hasattr(mod, "DB_PATH"):
                mod.DB_PATH = TEST_DB
            if class_name and hasattr(mod, class_name):
                getattr(mod, class_name)()
            elif hasattr(mod, "_ensure_schema"):
                mod._ensure_schema()
        except Exception:
            pass

    # Pass 2: create any missing tables directly
    if not TEST_DB.exists():
        return
    try:
        conn = sqlite3.connect(TEST_DB)
        existing = {r[0] for r in conn.execute(
            "SELECT name FROM sqlite_master WHERE type='table'").fetchall()}
        for table, ddl in _FALLBACK_TABLES.items():
            if table not in existing:
                try:
                    conn.execute(ddl)
                except Exception:
                    pass
        conn.commit()
        conn.close()
    except Exception:
        pass


def teardown():
    if TEST_DIR.exists():
        shutil.rmtree(TEST_DIR, ignore_errors=True)


