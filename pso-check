def setup():
    TEST_DIR.mkdir(parents=True, exist_ok=True)
    TEST_BACKUP_DIR.mkdir(parents=True, exist_ok=True)

    os.environ["PSO_DB_PATH"]   = str(TEST_DB)
    os.environ["PSO_DEV_DIR"]   = str(TEST_DIR)
    os.environ["PSO_TEST_MODE"] = "1"

    # Run pso init to create core schema
    subprocess.run(
        ["./pso", "init"],
        capture_output=True, text=True,
        cwd=str(SCRIPT_DIR),
        env={**os.environ},
        timeout=30,
    )

    # Instantiate every component that owns tables so schemas are created
    _bootstrap_schemas()
    return TEST_DB.exists()


