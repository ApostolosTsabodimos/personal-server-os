#!/bin/bash
# PSO Interactive Menu
# User-friendly interface for all PSO commands

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
PURPLE='\033[0;35m'
NC='\033[0m' # No Color

# Emoji for better UX
CHECK="✓"
CROSS="✗"
ARROW="→"
WARN="⚠"

clear

show_header() {
    echo -e "${CYAN}╔════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║${NC}                  ${GREEN}PSO - Personal Server OS${NC}                  ${CYAN}║${NC}"
    echo -e "${CYAN}║${NC}                  Interactive Control Panel                ${CYAN}║${NC}"
    echo -e "${CYAN}╚════════════════════════════════════════════════════════════╝${NC}"
    echo ""
}

show_main_menu() {
    show_header
    echo -e "${YELLOW}Main Menu:${NC}"
    echo ""
    echo -e "  ${GREEN}1${NC}) 📦 Service Management"
    echo -e "  ${GREEN}2${NC}) 📚 Service Catalog"
    echo -e "  ${GREEN}3${NC}) 🛡️  Firewall & Tiers"
    echo -e "  ${GREEN}4${NC}) 💚 Health Monitoring"
    echo -e "  ${GREEN}5${NC}) 👤 User Management"
    echo -e "  ${GREEN}6${NC}) 💾 Backup Management"
    echo -e "  ${GREEN}7${NC}) 📊 Development Tools"
    echo -e "  ${GREEN}8${NC}) 📖 Documentation"
    echo -e "  ${GREEN}9${NC}) ⚙️  System Info"
    echo -e "  ${RED}0${NC}) 🚪 Exit"
    echo ""
    read -p "Select option: " choice
    
    case $choice in
        1) service_menu ;;
        2) catalog_menu ;;
        3) firewall_menu ;;
        4) health_menu ;;
        5) user_menu ;;
        6) backup_menu ;;
        7) dev_menu ;;
        8) docs_menu ;;
        9) system_info ;;
        0) exit 0 ;;
        *) 
            echo -e "${RED}Invalid option${NC}"
            sleep 1
            show_main_menu
            ;;
    esac
}

service_menu() {
    clear
    show_header
    echo -e "${YELLOW}Service Management:${NC}"
    echo ""
    echo -e "  ${GREEN}1${NC}) List all services"
    echo -e "  ${GREEN}2${NC}) List installed services"
    echo -e "  ${GREEN}3${NC}) Install a service"
    echo -e "  ${GREEN}4${NC}) Uninstall a service"
    echo -e "  ${GREEN}5${NC}) Start a service"
    echo -e "  ${GREEN}6${NC}) Stop a service"
    echo -e "  ${GREEN}7${NC}) Restart a service"
    echo -e "  ${GREEN}8${NC}) View service logs"
    echo -e "  ${GREEN}9${NC}) Check service status"
    echo -e "  ${RED}0${NC}) ← Back to main menu"
    echo ""
    read -p "Select option: " choice
    
    case $choice in
        1) 
            ./pso list
            press_any_key
            service_menu
            ;;
        2)
            ./pso list | grep "Status: running\|Status: stopped"
            press_any_key
            service_menu
            ;;
        3)
            read -p "Enter service ID to install: " service_id
            ./pso install "$service_id"
            press_any_key
            service_menu
            ;;
        4)
            read -p "Enter service ID to uninstall: " service_id
            echo -e "${YELLOW}Are you sure? This will remove all data! (y/N)${NC}"
            read -p "> " confirm
            if [ "$confirm" = "y" ]; then
                ./pso uninstall "$service_id"
            fi
            press_any_key
            service_menu
            ;;
        5)
            read -p "Enter service ID to start: " service_id
            ./pso start "$service_id"
            press_any_key
            service_menu
            ;;
        6)
            read -p "Enter service ID to stop: " service_id
            ./pso stop "$service_id"
            press_any_key
            service_menu
            ;;
        7)
            read -p "Enter service ID to restart: " service_id
            ./pso restart "$service_id"
            press_any_key
            service_menu
            ;;
        8)
            read -p "Enter service ID: " service_id
            echo -e "${CYAN}Fetching logs for $service_id...${NC}"
            docker logs "pso-$service_id" --tail 50
            press_any_key
            service_menu
            ;;
        9)
            read -p "Enter service ID: " service_id
            ./pso status "$service_id" 2>/dev/null || docker ps -a | grep "pso-$service_id"
            press_any_key
            service_menu
            ;;
        0) show_main_menu ;;
        *) 
            echo -e "${RED}Invalid option${NC}"
            sleep 1
            service_menu
            ;;
    esac
}

