backup_menu() {
    clear
    show_header
    echo -e "${YELLOW}Backup Management:${NC}"
    echo ""
    echo -e "  ${GREEN}1${NC}) Create backup"
    echo -e "  ${GREEN}2${NC}) List backups"
    echo -e "  ${GREEN}3${NC}) Restore backup"
    echo -e "  ${RED}0${NC}) ← Back to main menu"
    echo ""
    read -p "Select option: " choice
    
    case $choice in
        1)
            read -p "Enter service ID: " service_id
            read -p "Enter note (optional): " note
            if [ -z "$note" ]; then
                ./pso backup "$service_id"
            else
                ./pso backup "$service_id" --note "$note"
            fi
            press_any_key
            backup_menu
            ;;
        2)
            read -p "Enter service ID (or leave empty for all): " service_id
            if [ -z "$service_id" ]; then
                python -c "from core.backup_manager import BackupManager; bm = BackupManager(); [print(f'{b[\"service_id\"]}: {b[\"backup_path\"]}') for b in bm.list_backups()]"
            else
                python -c "from core.backup_manager import BackupManager; bm = BackupManager(); [print(f'{b[\"backup_path\"]}') for b in bm.list_backups('$service_id')]"
            fi
            press_any_key
            backup_menu
            ;;
        3)
            echo -e "${YELLOW}Restore functionality coming soon...${NC}"
            press_any_key
            backup_menu
            ;;
        0) show_main_menu ;;
        *) 
            echo -e "${RED}Invalid option${NC}"
            sleep 1
            backup_menu
            ;;
    esac
}

