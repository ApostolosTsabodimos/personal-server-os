system_info() {
    clear
    show_header
    echo -e "${YELLOW}System Information:${NC}"
    echo ""
    
    # Docker status
    echo -e "${CYAN}Docker:${NC}"
    docker --version 2>/dev/null || echo "Not installed"
    echo ""
    
    # Database status
    echo -e "${CYAN}Database:${NC}"
    if [ -f "/var/pso/pso.db" ]; then
        echo -e "  ${GREEN}${CHECK}${NC} Database exists at /var/pso/pso.db"
        db_size=$(du -h /var/pso/pso.db | cut -f1)
        echo -e "  Size: $db_size"
    else
        echo -e "  ${YELLOW}${WARN}${NC} Database not found"
    fi
    echo ""
    
    # Services count
    echo -e "${CYAN}Services:${NC}"
    installed_count=$(./pso list 2>/dev/null | grep -c "Status:" || echo "0")
    echo -e "  Installed: $installed_count"
    echo ""
    
    # Web Dashboard
    echo -e "${CYAN}Web Dashboard:${NC}"
    if pgrep -f "web/api.py" > /dev/null; then
        echo -e "  ${GREEN}${CHECK}${NC} Running at http://localhost:5000"
    else
        echo -e "  ${YELLOW}${WARN}${NC} Not running"
        echo -e "  Start with: ${CYAN}cd web && python api.py${NC}"
    fi
    echo ""
    
    # Health Monitor
    echo -e "${CYAN}Health Monitor:${NC}"
    if pgrep -f "health_monitor.py" > /dev/null; then
        echo -e "  ${GREEN}${CHECK}${NC} Running"
    else
        echo -e "  ${YELLOW}${WARN}${NC} Not running (starts with API)"
    fi
    echo ""
    
    # iptables
    echo -e "${CYAN}Firewall (iptables):${NC}"
    if command -v iptables &> /dev/null; then
        echo -e "  ${GREEN}${CHECK}${NC} Installed"
        pso_rules=$(sudo iptables -L 2>/dev/null | grep -c "PSO_" || echo "0")
        echo -e "  Active PSO rules: $pso_rules"
    else
        echo -e "  ${RED}${CROSS}${NC} Not installed"
    fi
    echo ""
    
    press_any_key
    show_main_menu
}

press_any_key() {
    echo ""
    read -p "Press any key to continue..."
}

# Main entry point
show_main_menu