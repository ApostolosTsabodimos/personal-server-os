firewall_menu() {
    clear
    show_header
    echo -e "${YELLOW}Firewall & Tier Management:${NC}"
    echo ""
    echo -e "  ${GREEN}1${NC}) 📊 View tier definitions"
    echo -e "  ${GREEN}2${NC}) 📋 List all service tiers"
    echo -e "  ${GREEN}3${NC}) 🔍 Check service tier"
    echo -e "  ${GREEN}4${NC}) 🔼 Promote service tier"
    echo -e "  ${GREEN}5${NC}) 🔽 Demote service tier"
    echo -e "  ${GREEN}6${NC}) 📜 View tier change history"
    echo -e "  ${RED}7${NC}) ${WARN}  Emergency: Reset all to Tier 0"
    echo -e "  ${RED}0${NC}) ← Back to main menu"
    echo ""
    read -p "Select option: " choice
    
    case $choice in
        1)
            python -m core.firewall_manager tiers
            press_any_key
            firewall_menu
            ;;
        2)
            python -m core.firewall_manager list
            press_any_key
            firewall_menu
            ;;
        3)
            read -p "Enter service ID: " service_id
            python -m core.firewall_manager status "$service_id"
            press_any_key
            firewall_menu
            ;;
        4)
            read -p "Enter service ID: " service_id
            echo ""
            echo -e "${CYAN}Available tiers:${NC}"
            echo -e "  ${GREEN}0${NC} - 🟢 Internal Only (127.0.0.1)"
            echo -e "  ${GREEN}1${NC} - 🟡 LAN Only (192.168.x.x)"
            echo -e "  ${GREEN}2${NC} - 🔵 VPN Access (Tailscale/WireGuard)"
            echo -e "  ${RED}3${NC} - 🔴 Internet Exposed (PUBLIC - DANGER)"
            echo ""
            read -p "Enter new tier (0-3): " new_tier
            
            if [ "$new_tier" = "3" ]; then
                echo ""
                echo -e "${RED}${WARN} WARNING: Tier 3 exposes this service to the PUBLIC INTERNET!${NC}"
                echo -e "${YELLOW}Are you absolutely sure? (type 'yes' to confirm)${NC}"
                read -p "> " confirm
                if [ "$confirm" != "yes" ]; then
                    echo -e "${GREEN}Cancelled.${NC}"
                    sleep 1
                    firewall_menu
                    return
                fi
            fi
            
            sudo python -m core.firewall_manager set "$service_id" "$new_tier"
            echo ""
            echo -e "${GREEN}${CHECK} Tier changed successfully${NC}"
            echo -e "${YELLOW}Remember to restart the service for changes to take effect!${NC}"
            press_any_key
            firewall_menu
            ;;
        5)
            read -p "Enter service ID: " service_id
            echo ""
            python -m core.firewall_manager status "$service_id"
            echo ""
            read -p "Enter new tier (0-3, lower = safer): " new_tier
            sudo python -m core.firewall_manager set "$service_id" "$new_tier"
            press_any_key
            firewall_menu
            ;;
        6)
            read -p "Enter service ID: " service_id
            python -m core.firewall_manager history "$service_id"
            press_any_key
            firewall_menu
            ;;
        7)
            echo ""
            echo -e "${RED}${WARN} WARNING: This will reset ALL services to Tier 0 (Internal Only)${NC}"
            echo -e "${YELLOW}Type 'RESET' to confirm:${NC}"
            read -p "> " confirm
            if [ "$confirm" = "RESET" ]; then
                python -m core.firewall_manager reset-all
            else
                echo -e "${GREEN}Cancelled.${NC}"
            fi
            press_any_key
            firewall_menu
            ;;
        0) show_main_menu ;;
        *) 
            echo -e "${RED}Invalid option${NC}"
            sleep 1
            firewall_menu
            ;;
    esac
}

