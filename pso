                    info "Logs: $HOME/.pso_dev/dashboard.log"
                    if [ -f "$PSO_PID_FILE" ]; then
                        info "PID: $(cat "$PSO_PID_FILE")"
                    else
                        info "PID: $(pgrep -f 'api.py' | head -1) (no PID file — dashboard started outside PSO)"
                    fi
                else
                    warn "Dashboard not running"
                    # Clean up stale PID file if present
                    rm -f "$PSO_PID_FILE"
                    info "Start with: pso dashboard start"
                fi
                ;;
            restart)
                "$0" dashboard stop
                sleep 1
                "$0" dashboard start
                ;;
            secure)
                PSO_CERT="$HOME/.pso_dev/dashboard.crt"
                PSO_KEY="$HOME/.pso_dev/dashboard.key"
                mkdir -p "$HOME/.pso_dev"

                if [ -f "$PSO_CERT" ] && [ -f "$PSO_KEY" ]; then
                    warn "Certificate already exists at $PSO_CERT"
                    info "To regenerate: pso dashboard unsecure && pso dashboard secure"
                    exit 0
                fi

                info "Generating self-signed certificate..."
                if ! command -v openssl &>/dev/null; then
                    error "openssl not found — install it with: sudo apt install openssl"
                    exit 1
                fi

                openssl req -x509 -newkey rsa:4096 -sha256 -days 3650                     -nodes                     -keyout "$PSO_KEY"                     -out "$PSO_CERT"                     -subj "/CN=PSO Dashboard"                     -addext "subjectAltName=IP:127.0.0.1,IP:0.0.0.0,DNS:localhost"                     2>/dev/null

                if [ $? -eq 0 ]; then
                    success "Certificate generated (valid 10 years)"
                    info "  Cert: $PSO_CERT"
                    info "  Key:  $PSO_KEY"
                    info "Restarting dashboard with HTTPS..."
                    "$0" dashboard restart
                    info "Dashboard now at: https://localhost:5000"
                    warn "Your browser will warn about the self-signed cert — this is expected."
                    warn "Add a security exception to proceed."
                else
                    error "Failed to generate certificate"
                    rm -f "$PSO_CERT" "$PSO_KEY"
                    exit 1
                fi
                ;;
            unsecure)
                PSO_CERT="$HOME/.pso_dev/dashboard.crt"
                PSO_KEY="$HOME/.pso_dev/dashboard.key"

                if [ ! -f "$PSO_CERT" ] && [ ! -f "$PSO_KEY" ]; then
                    info "Dashboard is already running without HTTPS"
                    exit 0
                fi

                info "Removing certificate..."
                rm -f "$PSO_CERT" "$PSO_KEY"
                success "Certificate removed"
                info "Restarting dashboard without HTTPS..."
                "$0" dashboard restart
                info "Dashboard now at: http://localhost:5000"
                ;;
            logs)
                PSO_LOG_FILE="$HOME/.pso_dev/dashboard.log"
                if [ ! -f "$PSO_LOG_FILE" ]; then
                    error "No dashboard log found at $PSO_LOG_FILE"
                    info "Start the dashboard first: pso dashboard start"
                    exit 1
                fi
                case "${3:-tail}" in
                    follow|f|-f)
                        info "Following dashboard logs (Ctrl+C to stop)..."
                        tail -f "$PSO_LOG_FILE"
                        ;;
                    *)
                        # Default: show last 50 lines
                        tail -n "${3:-50}" "$PSO_LOG_FILE"
                        ;;
                esac
                ;;
            *)
                error "Unknown dashboard command: $2"
                echo "  Use: pso dashboard [start|stop|status|restart|logs|secure|unsecure]"
                echo ""
                echo "  pso dashboard logs             Show last 50 lines"
                echo "  pso dashboard logs follow      Follow live (Ctrl+C to stop)"
                echo "  pso dashboard logs <N>         Show last N lines"
                exit 1
                ;;
        esac
        ;;

    # ── Development / progress tracking ──────────────────────────────────────
    dev)
        case "$2" in
            scan)
                # init first so scan never fails on missing data file
                python3 pso.py init 2>/dev/null | grep -v "^$" || true
                python3 pso.py scan
                ;;
            tree|status|architecture)
                python3 pso.py "$2"
                ;;
            complete)
                [ -z "$3" ] && { error "Component ID required"; exit 1; }
                python3 pso.py complete "$3"
                ;;
            *)
                error "Unknown dev command: $2"
                echo "Use: pso dev [scan|tree|status|architecture|complete]"
                exit 1
                ;;
        esac
        ;;

    # ── Daemon install / uninstall ───────────────────────────────────────────
    install-daemon)
        PSO_DIR="$(cd "$(dirname "$0")" && pwd)"
        PSO_SCRIPT="$PSO_DIR/pso"
        PSO_LOG="$HOME/.pso_dev/dashboard.log"
        OS_TYPE="$(uname -s)"

        if [ "$OS_TYPE" = "Darwin" ]; then
            # ── macOS: launchd user agent ─────────────────────────────────
            PLIST_DIR="$HOME/Library/LaunchAgents"
            PLIST_FILE="$PLIST_DIR/com.pso.dashboard.plist"
            mkdir -p "$PLIST_DIR"

            # Find Python
            if [ -f "$PSO_DIR/.venv/bin/python3" ]; then
                PYTHON="$PSO_DIR/.venv/bin/python3"
            elif [ -f "$PSO_DIR/venv/bin/python3" ]; then
                PYTHON="$PSO_DIR/venv/bin/python3"
            else
                PYTHON="$(command -v python3)"
            fi

            python3 "$PSO_DIR/scripts/generate_launchd_plist.py"                 --python "$PYTHON"                 --pso-dir "$PSO_DIR"                 --log "$PSO_LOG"                 --output "$PLIST_FILE"

            if [ $? -ne 0 ]; then
                error "Failed to generate launchd plist"
                exit 1
            fi

            launchctl load -w "$PLIST_FILE" 2>/dev/null ||             launchctl bootstrap gui/"$(id -u)" "$PLIST_FILE" 2>/dev/null

            if [ $? -eq 0 ]; then
                success "PSO dashboard registered as launchd agent"
                info "  Plist: $PLIST_FILE"
                info "  Starts automatically on login"
                info "  Logs: $PSO_LOG"
                info "To start now: launchctl start com.pso.dashboard"
            else
                error "Failed to register launchd agent"
                exit 1
            fi

        else
            # ── Linux: systemd user service ───────────────────────────────
            SYSTEMD_DIR="$HOME/.config/systemd/user"
            SERVICE_FILE="$SYSTEMD_DIR/pso-dashboard.service"
            mkdir -p "$SYSTEMD_DIR"

            # Find Python
            if [ -f "$PSO_DIR/.venv/bin/python3" ]; then
                PYTHON="$PSO_DIR/.venv/bin/python3"
            elif [ -f "$PSO_DIR/venv/bin/python3" ]; then
                PYTHON="$PSO_DIR/venv/bin/python3"
            else
                PYTHON="$(command -v python3)"
            fi

            cat > "$SERVICE_FILE" << SYSTEMD_EOF
[Unit]
Description=PSO Dashboard
Documentation=https://github.com/ApostolosTsampodimos/personal-server-os
After=network.target docker.service
Wants=docker.service

[Service]
Type=simple
WorkingDirectory=$PSO_DIR/web
ExecStart=$PYTHON $PSO_DIR/web/api.py
Restart=on-failure
RestartSec=5
StandardOutput=append:$PSO_LOG
StandardError=append:$PSO_LOG
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=default.target
SYSTEMD_EOF

            systemctl --user daemon-reload
            systemctl --user enable pso-dashboard.service
            systemctl --user start pso-dashboard.service

            if systemctl --user is-active --quiet pso-dashboard.service; then
                success "PSO dashboard running as systemd user service"
                info "  Unit: $SERVICE_FILE"
                info "  Starts automatically on login"
                info "  Logs: $PSO_LOG  (or: journalctl --user -u pso-dashboard)"
                info "Commands:"
                info "  systemctl --user status pso-dashboard"
                info "  systemctl --user restart pso-dashboard"
            else
                error "Service installed but failed to start"
                info "Check logs: journalctl --user -u pso-dashboard --no-pager -n 30"
                exit 1
            fi

            # Enable lingering so service survives after logout
            loginctl enable-linger "$USER" 2>/dev/null || true
        fi
        ;;

    uninstall-daemon)
        OS_TYPE="$(uname -s)"

        if [ "$OS_TYPE" = "Darwin" ]; then
            PLIST_FILE="$HOME/Library/LaunchAgents/com.pso.dashboard.plist"
            if [ ! -f "$PLIST_FILE" ]; then
                info "No launchd agent installed"
                exit 0
            fi
            launchctl stop com.pso.dashboard 2>/dev/null || true
            launchctl unload -w "$PLIST_FILE" 2>/dev/null ||             launchctl bootout gui/"$(id -u)" "$PLIST_FILE" 2>/dev/null || true
            rm -f "$PLIST_FILE"
            success "launchd agent removed"

        else
            SERVICE="pso-dashboard.service"
            SERVICE_FILE="$HOME/.config/systemd/user/$SERVICE"
            if [ ! -f "$SERVICE_FILE" ]; then
                info "No systemd user service installed"
                exit 0
            fi
            systemctl --user stop    "$SERVICE" 2>/dev/null || true
            systemctl --user disable "$SERVICE" 2>/dev/null || true
            rm -f "$SERVICE_FILE"
            systemctl --user daemon-reload
            success "systemd user service removed"
        fi
        ;;

    # ── Pause / Resume (laptop workflow) ─────────────────────────────────────
    pause)
        info "Pausing PSO — stopping all services and dashboard..."
        echo

        # 1. Stop all running containers
        CONTAINERS=$(docker ps --filter "name=pso-" --format "{{.Names}}" 2>/dev/null)
        if [ -n "$CONTAINERS" ]; then
            while IFS= read -r name; do
                SERVICE_ID="${name#pso-}"
                if docker stop "$name" >/dev/null 2>&1; then
                    success "Stopped: $SERVICE_ID"
                else
                    error "Failed to stop: $SERVICE_ID"
                fi
            done <<< "$CONTAINERS"
        else
            info "No services were running"
        fi

        # 2. Stop the dashboard process
        echo
        STOPPED=0
        if [ -f "$HOME/.pso_dev/dashboard.pid" ]; then
            kill "$(cat "$HOME/.pso_dev/dashboard.pid")" 2>/dev/null && STOPPED=1
            rm -f "$HOME/.pso_dev/dashboard.pid"
        fi
        pkill -f "api.py" 2>/dev/null && STOPPED=1
        [ "$STOPPED" -eq 1 ] && success "Dashboard stopped" || info "Dashboard was not running"

        echo
        success "PSO paused. Run 'pso resume' when you're back."
        ;;

    resume)
        info "Resuming PSO — starting dashboard and all services..."
        echo

        # 1. Start the dashboard
        PSO_LOG_FILE="$HOME/.pso_dev/dashboard.log"
        PSO_PID_FILE="$HOME/.pso_dev/dashboard.pid"
        pkill -f "api.py" 2>/dev/null || true
        rm -f "$PSO_PID_FILE"
        mkdir -p "$HOME/.pso_dev"
        cd web
        nohup python3 api.py >"$PSO_LOG_FILE" 2>&1 &
        echo $! > "$PSO_PID_FILE"
        sleep 2
        if pgrep -f "api.py" >/dev/null; then
            success "Dashboard started — http://localhost:5000"
        else
            error "Dashboard failed to start — check: $PSO_LOG_FILE"
        fi
        cd "$SCRIPT_DIR"

        # 2. Start all PSO containers
        echo
        CONTAINERS=$(docker ps -a --filter "name=pso-" --format "{{.Names}}" 2>/dev/null)
        if [ -n "$CONTAINERS" ]; then
            STARTED=0
            SKIPPED=0
            while IFS= read -r name; do
                SERVICE_ID="${name#pso-}"
                STATUS=$(docker inspect --format "{{.State.Status}}" "$name" 2>/dev/null)
                if [ "$STATUS" = "running" ]; then
                    info "Already running: $SERVICE_ID"
                    SKIPPED=$((SKIPPED + 1))
                elif docker start "$name" >/dev/null 2>&1; then
                    success "Started: $SERVICE_ID"
                    STARTED=$((STARTED + 1))
                else
                    error "Failed to start: $SERVICE_ID"
                fi
            done <<< "$CONTAINERS"
            echo
            [ $STARTED -gt 0 ]  && success "$STARTED service(s) started"
            [ $SKIPPED -gt 0 ]  && info    "$SKIPPED already running"
        else
            info "No PSO services found to start"
        fi

        echo
        success "PSO resumed. Dashboard at http://localhost:5000"
        ;;

    # ── Bulk service control ──────────────────────────────────────────────────
    stop-all)
        info "Stopping all PSO services..."
        CONTAINERS=$(docker ps --filter "name=pso-" --format "{{.Names}}" 2>/dev/null)
        if [ -z "$CONTAINERS" ]; then
            warn "No PSO services are currently running"
            exit 0
        fi
        COUNT=0
        while IFS= read -r name; do
            SERVICE_ID="${name#pso-}"
            if docker stop "$name" >/dev/null 2>&1; then
                success "Stopped: $SERVICE_ID"
                COUNT=$((COUNT + 1))
            else
                error "Failed to stop: $SERVICE_ID"
            fi
        done <<< "$CONTAINERS"
        echo
        success "$COUNT service(s) stopped"
        info "To start them again: pso start-all"
        ;;

    start-all)
        info "Starting all installed PSO services..."
        CONTAINERS=$(docker ps -a --filter "name=pso-" --format "{{.Names}}" 2>/dev/null)
        if [ -z "$CONTAINERS" ]; then
            warn "No PSO services found"
            info "Install a service first: pso catalog"
            exit 0
        fi
        STARTED=0
        SKIPPED=0
        FAILED=0
        while IFS= read -r name; do
            SERVICE_ID="${name#pso-}"
            STATUS=$(docker inspect --format "{{.State.Status}}" "$name" 2>/dev/null)
            if [ "$STATUS" = "running" ]; then
                info "Already running: $SERVICE_ID"
                SKIPPED=$((SKIPPED + 1))
            elif docker start "$name" >/dev/null 2>&1; then
                success "Started: $SERVICE_ID"
                STARTED=$((STARTED + 1))
            else
                error "Failed to start: $SERVICE_ID"
                FAILED=$((FAILED + 1))
            fi
        done <<< "$CONTAINERS"
        echo
        [ $STARTED -gt 0 ]  && success "$STARTED service(s) started"
        [ $SKIPPED -gt 0 ]  && info    "$SKIPPED already running"
        [ $FAILED -gt 0 ]   && error   "$FAILED failed to start"
        ;;

    # NOTE: 'docs' command removed -- it was a redundant alias for pso-menu.
    # Run pso-menu directly.

    *)
        error "Unknown command: $1"
        echo
        echo "  pso help          Show all commands"
        echo "  pso catalog       Browse available services"
        echo "  pso-menu          Interactive menu"
        echo
        exit 1
        ;;

esac