    for svc_id in sorted(services):
        svc = services[svc_id]
        col = status_color(svc_id)
        print(f"    {col}●{RESET}  {BOLD}{svc_id}{RESET}  {DIM}standalone{RESET}")
    print()
    sys.exit(0)

# Draw dependency chains top-down
# Find services with no dependents (top of chain)
top_level = [s for s in services if not required_by.get(s) and depends_on.get(s)]
bottom    = [s for s in services if not depends_on.get(s)]

printed = set()

def print_tree(svc_id, prefix="", is_last=True, depth=0):
    if depth > 6:
        return
    connector = "└─ " if is_last else "├─ "
    col = status_color(svc_id)
    svc = services.get(svc_id, {})
    name = svc.get('service_name', svc_id)
    cycle_mark = f"  {DIM}(↑ already shown){RESET}" if svc_id in printed else ""
    print(f"  {prefix}{connector}{col}{BOLD}{svc_id}{RESET}  {DIM}{name}{RESET}{cycle_mark}")
    if svc_id not in printed:
        printed.add(svc_id)
        deps = sorted(depends_on.get(svc_id, []))
        for i, dep in enumerate(deps):
            ext = "   " if is_last else "│  "
            print_tree(dep, prefix + ext, i == len(deps)-1, depth+1)

# Print each top-level chain
shown_roots = set()
for svc_id in sorted(services):
    if not required_by.get(svc_id) and depends_on.get(svc_id):
        if svc_id not in shown_roots:
            shown_roots.add(svc_id)
            col = status_color(svc_id)
            svc = services.get(svc_id, {})
            name = svc.get('service_name', svc_id)
            print(f"\n  {col}{BOLD}{svc_id}{RESET}  {DIM}{name}{RESET}")
            deps = sorted(depends_on.get(svc_id, []))
            for i, dep in enumerate(deps):
                print_tree(dep, "", i == len(deps)-1)

# Standalone services (no edges at all)
if standalone:
