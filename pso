import sys, json
sys.path.insert(0, '$SCRIPT_DIR')
from core.database import Database

BOLD  = "\033[1m"
GREEN = "\033[0;32m"
CYAN  = "\033[1;36m"
DIM   = "\033[2m"
YELLOW= "\033[1;33m"
RED   = "\033[0;31m"
RESET = "\033[0m"

db = Database()

# Load all services and dependency edges
services  = {s['service_id']: s for s in db.list_services()}
edges = []  # (service_id, depends_on)

with db._get_connection() as conn:
    rows = conn.execute("SELECT service_id, depends_on FROM service_dependencies").fetchall()
    for r in rows:
        edges.append((r['service_id'], r['depends_on']))

focus = '$SERVICE_ID'.strip()

if not services:
    print("\n  No services installed.\n")
    sys.exit(0)

if focus and focus not in services:
    print(f"\n  {RED}Service not found: {focus}{RESET}")
    print(f"  Run 'pso deps' to see all, or 'pso list' for installed services.\n")
    sys.exit(1)

# Build adjacency: who does each service depend on, and who depends on it
depends_on  = {}   # service_id  → [list of services it needs]
required_by = {}   # service_id  → [list of services that need it]
for svc_id in services:
    depends_on[svc_id]  = []
    required_by[svc_id] = []

for (svc, dep) in edges:
    if svc in depends_on:
        depends_on[svc].append(dep)
    if dep in required_by:
        required_by[dep].append(svc)

def status_color(svc_id):
    st = services.get(svc_id, {}).get('status', 'unknown')
    return {
        'running':  GREEN,
        'stopped':  RED,
        'error':    RED,
        'imported': DIM,
    }.get(st, DIM)

def svc_label(svc_id):
    svc = services.get(svc_id, {})
    name = svc.get('service_name', svc_id)
    col  = status_color(svc_id)
    return f"{col}{BOLD}{svc_id}{RESET}{DIM} ({name}){RESET}"

# ── Single service view ────────────────────────────────────────────────────
if focus:
    svc = services[focus]
    print(f"\n  {BOLD}Dependency map: {focus}{RESET}")
    print("  " + "─" * 56)

    deps = depends_on.get(focus, [])
    revs = required_by.get(focus, [])

    if deps:
        print(f"\n  {CYAN}Depends on:{RESET}  ({focus} needs these to run)")
        for d in sorted(deps):
            col = status_color(d)
            st  = services.get(d, {}).get('status', 'not installed')
            installed = "✓" if d in services else "✗ NOT INSTALLED"
            print(f"    {col}{'✓' if d in services else '✗'}{RESET}  {svc_label(d)}")
    else:
        print(f"\n  {DIM}No dependencies — {focus} runs standalone{RESET}")

    if revs:
        print(f"\n  {CYAN}Required by:{RESET}  (these need {focus})")
        for r in sorted(revs):
            print(f"    ▸  {svc_label(r)}")
    else:
        print(f"\n  {DIM}Nothing depends on {focus}{RESET}")

    print()
    sys.exit(0)

# ── Full graph view ────────────────────────────────────────────────────────
# Find roots (services nobody depends on) and leaves (services with no deps)
roots  = [s for s in services if not required_by.get(s)]
leaves = [s for s in services if not depends_on.get(s)]
all_connected = set(s for (a,b) in edges for s in (a,b))
standalone = [s for s in services if s not in all_connected]

print(f"\n  {BOLD}Service Dependency Graph{RESET}  ({len(services)} services, {len(edges)} dependencies)")
print("  " + "─" * 60)

if not edges:
    print(f"\n  {DIM}No dependencies recorded yet.")
