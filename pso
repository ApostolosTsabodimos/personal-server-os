# ─────────────────────────────────────────────────────────────────────────────
# doctor
# ─────────────────────────────────────────────────────────────────────────────
doctor() {
    echo -e "${BOLD}PSO System Diagnostics${RESET}"
    echo "════════════════════════════════════════════"
    echo

    command -v python3 &>/dev/null && success "Python 3 installed" || error "Python 3 not found"

    if command -v docker &>/dev/null; then
        success "Docker installed"
        docker ps &>/dev/null && success "Docker running" || error "Docker not running"
    else
        error "Docker not installed"
    fi

    python3 << 'PYEOF'
import sys
deps = {
    'flask':      'Flask web framework',
    'docker':     'Docker SDK',
    'jwt':        'PyJWT authentication',
    'bcrypt':     'Password hashing',
    'jsonschema': 'Manifest validation',
}
missing = []
for module, desc in deps.items():
    try:
        __import__(module)
        print(f"  OK  {desc}")
    except ImportError:
        print(f"  MISSING  {desc}")
        missing.append(module)
if missing:
    print(f"\nInstall missing: pip install {' '.join(missing)} --break-system-packages")
    sys.exit(1)
PYEOF

    if [ -f "/var/pso/pso.db" ] || [ -f "$HOME/.pso_dev/pso.db" ]; then
        success "Database found"
    else
        warn "Database not initialized -- run: pso init"
    fi

    pgrep -f "api.py" >/dev/null && success "Dashboard running" || info "Dashboard not running (pso dashboard start)"

    echo
    success "Diagnostics complete"
}

# ─────────────────────────────────────────────────────────────────────────────
# fix-blockers
# ─────────────────────────────────────────────────────────────────────────────
fix_blockers() {
    echo -e "${BOLD}Fixing Common Issues...${RESET}"
    echo

    info "Installing missing dependencies..."
    pip install jsonschema flask docker PyJWT bcrypt --break-system-packages &>/dev/null \
        && success "Dependencies installed" || warn "Check pip installation"

    info "Initializing database..."
    python3 << 'PYEOF' &>/dev/null && success "Database initialized" || warn "Database may already exist"
from core.database import Database
from core.port_manager import PortManager
Database()
PortManager()
PYEOF

    if sudo netstat -tuln 2>/dev/null | grep -q ":80 "; then
        warn "Port 80 in use -- attempting to free..."
        sudo fuser -k 80/tcp &>/dev/null && success "Port 80 freed" || warn "Could not free port 80"
    else
        success "Port 80 available"
    fi

    info "Clearing Python cache..."
    find . -type d -name "__pycache__" -exec rm -rf {} + 2>/dev/null || true
    find . -type f -name "*.pyc" -delete 2>/dev/null || true
    success "Cache cleared"

    echo
    success "Done! Clear browser cache and refresh dashboard."
}

